# Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_SKILL_BRIDGE_API_URL=https://your-api-domain.com/api

# External APIs (if needed)
# OPENAI_API_KEY=your_openai_key_here
# GEMINI_API_KEY=your_gemini_key_here

# Power Apps / Power Automate Integration
POWER_APPS_ENVIRONMENT_URL=https://your-env.crm.dynamics.com
POWER_AUTOMATE_WEBHOOK_URL=https://your-webhook-url

# SharePoint Integration (if applicable)
SHAREPOINT_SITE_URL=https://yourtenant.sharepoint.com/sites/yoursite
SHAREPOINT_CLIENT_ID=your-sharepoint-client-id
SHAREPOINT_CLIENT_SECRET=your-sharepoint-client-secret

# Database (if using direct database connection)
# DATABASE_URL=your_database_connection_string

# Authentication (if implementing auth)
# AUTH_SECRET=your_auth_secret
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your_nextauth_secret