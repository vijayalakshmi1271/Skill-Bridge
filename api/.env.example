# API Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3001
NODE_ENV=development

# AI Service API Keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_google_gemini_api_key_here

# Database Configuration (if using MongoDB)
MONGODB_URI=mongodb://localhost:27017/skillbridge
# Or for cloud MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/skillbridge

# Authentication (if implementing user auth)
JWT_SECRET=your_jwt_secret_key_here
BCRYPT_ROUNDS=12

# External APIs
LINKEDIN_API_KEY=your_linkedin_api_key
INDEED_API_KEY=your_indeed_api_key

# Power Automate Integration
POWER_AUTOMATE_WEBHOOK_URL=https://your-power-automate-webhook-url
POWER_AUTOMATE_API_KEY=your_power_automate_api_key

# SharePoint Integration
SHAREPOINT_TENANT_ID=your_sharepoint_tenant_id
SHAREPOINT_CLIENT_ID=your_sharepoint_client_id
SHAREPOINT_CLIENT_SECRET=your_sharepoint_client_secret
SHAREPOINT_SITE_URL=https://yourtenant.sharepoint.com/sites/yoursite

# Email Service (for notifications)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# Logging
LOG_LEVEL=info

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://skill-bridge-two-zeta.vercel.app